.PHONY: setup ingest serve eval clean

setup:
	python -m venv venv
	source venv/bin/activate && pip install -r requirements.txt
	docker-compose up -d  # Starts pgvector + redis

ingest:
	python scripts/ingest_data.py --source data/raw/

serve:
	uvicorn src.serving.api:app --reload --port 8000

eval:
	python scripts/run_eval.py --config config/eval_config.yaml

test:
	pytest tests/ -v --cov=src

clean:
	docker-compose down -v
	rm -rf data/processed/* logs/*